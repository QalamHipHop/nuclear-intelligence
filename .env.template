# ============================================================
# Nuclear Intelligence v4.0 - Configuration Template
# Copy this to .env and fill in your API keys
# All providers are FREE - no credit card needed!
# ============================================================

# ─── HuggingFace Token ───────────────────────────────────────────
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ─── Free LLM Providers ────────────────────────────────────────
# Get free keys at the links below - no credit card needed!

# DeepSeek V3 - Best free model, 128K context ⭐⭐⭐
# https://console.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_deepseek_key

# Groq LPU - Fastest inference, free tier available ⭐⭐⭐
# https://console.groq.com/api-keys
GROQ_API_KEY=your_groq_key

# Google Gemini 2.0 Flash - Free tier ⭐⭐
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key

# Together AI - Free credits available ⭐⭐
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_key

# OpenRouter - Free daily credits ⭐
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# Novita AI - Free tier with DeepSeek V3 ⭐⭐
# https://novita.ai/api-keys
NOVITA_API_KEY=your_novita_key

# Fireworks AI - Free tier available ⭐⭐
# https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your_fireworks_key

# Cerebras - Free fast inference ⭐⭐⭐
# https://cloud.cerebras.ai/api-key
CEREBRAS_API_KEY=your_cerebras_key

# Cloudflare Workers AI
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_KEY=your_cloudflare_key

# ─── Blockchain ────────────────────────────────────────────────
BLOCKCHAIN_SECRET=nuclear-intelligence-v4-secret
EXTERNAL_NETWORK_RPC=
EXTERNAL_NETWORK_CONTRACT=

# ─── System Configuration ──────────────────────────────────────
DEVELOPER_MODE=true
AUTO_START_LOOP=true
OPERATION_LOOP_INTERVAL_MINUTES=30

# Quality thresholds
SCIENTIFIC_ACCURACY_THRESHOLD=93
MIN_NOVELTY_THRESHOLD=70
MIN_USEFULNESS_THRESHOLD=75
MIN_OVERALL_SCORE=82
MIN_COMPLETENESS_THRESHOLD=50

# ─── Security ─────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=60

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/nuclear_intelligence.log

# ─── API & UI ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860
GRADIO_SHARE=false

# ─── HuggingFace Space ─────────────────────────────────────────
SPACE_ID=Qalam/Nuclear-Intelligence